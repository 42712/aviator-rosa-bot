{
  "manifest_version": 3,
  "name": "Painel Aviator - Coletor",
  "version": "4.1",
  "description": "Coletor de rodadas do Aviator. Envia velas para o painel via webhook.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://*.betou.bet.br/*",
    "https://*.sortenabet.bet.br/*",
    "https://*.spribegaming.com/*",
    "https://painel-aviator.onrender.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": [
      "https://*.betou.bet.br/*",
      "https://*.sortenabet.bet.br/*",
      "https://*.spribegaming.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": true
  }],
  "web_accessible_resources": [{
    "resources": ["main-world.js"],
    "matches": [
      "https://*.betou.bet.br/*",
      "https://*.sortenabet.bet.br/*",
      "https://*.spribegaming.com/*"
    ]
  }],
  "action": { "default_popup": "popup.html", "default_title": "Painel Aviator" }
}
