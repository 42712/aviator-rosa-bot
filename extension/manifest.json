{
  "manifest_version": 3,
  "name": "Painel Aviator - Coletor",
  "version": "1.0",
  "description": "Coleta dados do Aviator em tempo real e envia para o painel",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.sortedabet.com/*",
    "https://*.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.sortedabet.com/*",
        "https://*.sorte da bet/*",
        "https://*.bet/*",
        "https://*.casino/*",
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
