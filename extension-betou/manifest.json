{
  "manifest_version": 3,
  "name": "Painel Aviator - Betou Coletor",
  "version": "1.0",
  "description": "Coleta dados do Aviator da Betou em tempo real e envia para o painel",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://betou.bet.br/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://betou.bet.br/games/spribe/aviator*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
