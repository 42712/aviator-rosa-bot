{
  "manifest_version": 3,
  "name": "Betou Coletor",
  "version": "6.2",
  "description": "Captura velas, rodada e horario do Aviator em tempo real via WebSocket + DOM",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://painel-aviator.onrender.com/*",
    "https://*.betou.bet.br/*",
    "https://*.spribegaming.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.betou.bet.br/*",
        "https://*.spribegaming.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [{
    "resources": ["main.js"],
    "matches": ["https://*.betou.bet.br/*", "https://*.spribegaming.com/*"]
  }],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Betou Coletor"
  }
}
